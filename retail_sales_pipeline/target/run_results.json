t(*) as n_records\n\nfrom \"neondb\".\"dbt_hirashahbaz\".\"bronze_sales\"\nwhere sale_id is not null\ngroup by sale_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-03T18:15:28.080832Z", "completed_at": "2026-07-03T18:15:28.090000Z"}, {"name": "execute", "started_at": "2026-07-03T18:15:28.095147Z", "completed_at": "2026-07-03T18:15:28.095157Z"}], "thread_id": "Thread-3 (worker)", "execution_time": 0.05529165267944336, "adapter_response": {}, "message": null, "failures": null, "unique_id": "model.retail_sales_pipeline.silver_sales", "compiled": true, "compiled_code": "-- Silver Layer: Cleaned and enriched sales data\n-- Joins sales with customer and store data\n-- Calculates derived fields\n\nwith sales as (\n    select * from \"neondb\".\"dbt_hirashahbaz\".\"bronze_sales\"\n),\n\ncustomers as (\n    select * from \"neondb\".\"dbt_hirashahbaz\".\"bronze_customers\"\n),\n\nstores as (\n    select * from \"neondb\".\"dbt_hirashahbaz\".\"bronze_stores\"\n)\n\nselect\n    -- Sale identifiers\n    s.sale_id,\n    cast(s.sale_date as date)                           as sale_date,\ndate_part('year', cast(s.sale_date as date))   as sale_year,\ndate_part('month', cast(s.sale_date as date))  as sale_month,\n\n    -- Customer info\n    s.customer_id,\n    c.first_name || ' ' || c.last_name                 as customer_name,\n    c.customer_segment,\n\n    -- Product info\n    s.product_id,\n    s.product_name,\n    s.category                                          as product_category,\n\n    -- Store info\n    s.store_id,\n    st.store_name,\n    st.city                                             as store_city,\n    st.region                                           as store_region,\n\n    -- Sales metrics\n    s.quantity,\n    s.unit_price,\n    s.quantity * s.unit_price                           as total_sale_amount,\n\n    -- Data quality flag\n    case\n        when s.quantity <= 0 then 'INVALID'\n        when s.unit_price <= 0 then 'INVALID'\n        else 'VALID'\n    end                                                 as record_status\n\nfrom sales s\nleft join customers c on s.customer_id = c.customer_id\nleft join stores st   on s.store_id = st.store_id", "relation_name": "\"neondb\".\"dbt_hirashahbaz\".\"silver_sales\"", "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-03T18:15:28.101739Z", "completed_at": "2026-07-03T18:15:28.126329Z"}, {"name": "execute", "started_at": "2026-07-03T18:15:28.140168Z", "completed_at": "2026-07-03T18:15:28.140182Z"}], "thread_id": "Thread-4 (worker)", "execution_time": 0.04569101333618164, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.retail_sales_pipeline.not_null_bronze_customers_customer_id.254c74eb6e", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect customer_id\nfrom \"neondb\".\"dbt_hirashahbaz\".\"bronze_customers\"\nwhere customer_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-03T18:15:28.114787Z", "completed_at": "2026-07-03T18:15:28.138763Z"}, {"name": "execute", "started_at": "2026-07-03T18:15:28.141241Z", "completed_at": "2026-07-03T18:15:28.141251Z"}], "thread_id": "Thread-5 (worker)", "execution_time": 0.043479204177856445, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.retail_sales_pipeline.not_null_bronze_stores_store_id.e908d93677", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect store_id\nfrom \"neondb\".\"dbt_hirashahbaz\".\"bronze_stores\"\nwhere store_id is null\n\n\n", "relation_name": null, "batch_results": null, "overload_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-03T18:15:28.109284Z", "completed_at": "2026-07