"adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.retail_sales_pipeline.unique_bronze_stores_store_id.54c55eb04d", "compiled": true, "compiled_code": "\n    \n    \n\nselect\n    store_id as unique_field,\n    count(*) as n_records\n\nfrom \"dev\".\"main\".\"bronze_stores\"\nwhere store_id is not null\ngroup by store_id\nhaving count(*) > 1\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-07-01T22:10:21.821066Z", "completed_at": "2026-07-01T22:10:21.831996Z"}, {"name": "execute", "started_at": "2026-07-01T22:10:21.832943Z", "completed_at": "2026-07-01T22:10:21.981949Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.16463088989257812, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.retail_sales_pipeline.silver_sales", "compiled": true, "compiled_code": "-- Silver Layer: Cleaned and enriched sales data\n-- Joins sales with customer and store data\n-- Calculates derived fields\n\nwith sales as (\n    select * from \"dev\".\"main\".\"bronze_sales\"\n),\n\ncustomers as (\n    select * from \"dev\".\"main\".\"bronze_customers\"\n),\n\nstores as (\n    select * from \"dev\".\"main\".\"bronze_stores\"\n)\n\nselect\n    -- Sale identifiers\n    s.sale_id,\n    cast(s.sale_date as date)                           as sale_date,\n    extract(year from cast(s.sale_date as date))        as sale_year,\n    extract(month from cast(s.sale_date as date))       as sale_month,\n\n    -- Customer info\n    s.customer_id,\n    c.first_name || ' ' || c.last_name                 as customer_name,\n    c.customer_segment,\n\n    -- Product info\n    s.product_id,\n    s.product_name,\n    s.category                                          as product_category,\n\n    -- Store info\n    s.store_id,\n    st.store_name,\n    st.city                                             as store_city,\n    st.region                                           as store_region,\n\n    -- Sales metrics\n    s.quantity,\n    s.unit_price,\n    s.quantity * s.unit_price                           as total_sale_amount,\n\n    -- Data quality flag\n    case\n        when s.quantity <= 0 then 'INVALID'\n        when s.unit_price <= 0 then 'INVALID'\n        else 'VALID'\n    end                                                 as record_status\n\nfrom sales s\nleft join customers c on s.customer_id = c.customer_id\nleft join stores st   on s.store_id = st.store_id", "relation_name": "\"dev\".\"main\".\"silver_sales\"", "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-07-01T22:10:21.994558Z", "completed_at": "2026-07-01T22:10:22.025113Z"}, {"name": "execute", "started_at": "2026-07-01T22:10:22.026922Z", "completed_at": "2026-07-01T22:10:22.062174Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.07558703422546387, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.retail_sales_pipeline.accepted_values_silver_sales_record_status__VALID__INVALID.6c49b63ae3", "compiled": true, "compiled_code": "\n    \n    \n\nwith all_values as (\n\n    select\n        record_status as value_field,\n        count(*) as n_records\n\n    from \"dev\".\"main\".\"silver_sales\"\n    group by record_status\n\n)\n\nselect *\nfrom all_values\nwhere value_field not in (\n    'VALID','INVALID'\n)\n\n\n", "relation_name": null, "batch_results": null}, {"status": "pass", "timing": [{"name": "compile", "started_at": "2026-07-01T22:10:22.077572Z", "completed_at": "2026-07-01T22:10:22.090257Z"}, {"name": "execute", "started_at": "2026-07-01T22:10:22.091037Z", "completed_at": "2026-07-01T22:10:22.117763Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.04862260818481445, "adapter_response": {"_message": "OK"}, "message": null, "failures": 0, "unique_id": "test.retail_sales_pipeline.not_null_silver_sales_sale_id.48c401fbc3", "compiled": t